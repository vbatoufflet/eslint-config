{
  "name": "@batou.dev/eslint-config",
  "version": "0.2.1",
  "description": "Reusable ESLint configuration with JavaScript and TypeScript support",
  "license": "MIT",
  "author": "Vincent Batoufflet <vincent@batou.dev>",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbatoufflet/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/vbatoufflet/eslint-config/issues"
  },
  "homepage": "https://github.com/vbatoufflet/eslint-config#readme",
  "files": [
    "dist/",
    "CHANGELOG.md",
    "README.md"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "scripts": {
    "build": "vite build && tsc --project tsconfig.build.json",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.14",
    "eslint": "^10.7.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-externalize-deps": "^0.10.0"
  },
  "peerDependencies": {
    "@eslint/compat": "^1.3.1 || ^2.0.0",
    "@eslint/js": "^9.31.0 || ^10.0.0",
    "@stylistic/eslint-plugin": "^5.2.2",
    "eslint": "^9.31.0 || ^10.0.0",
    "eslint-plugin-perfectionist": "^4.15.0 || ^5.0.0",
    "typescript": "^5.8.3 || ^6.0.0",
    "typescript-eslint": "^8.38.0"
  },
  "peerDependenciesMeta": {
    "@eslint/compat": {
      "optional": true
    },
    "@eslint/js": {
      "optional": false
    },
    "@stylistic/eslint-plugin": {
      "optional": false
    },
    "eslint": {
      "optional": false
    },
    "eslint-plugin-perfectionist": {
      "optional": false
    },
    "typescript": {
      "optional": true
    },
    "typescript-eslint": {
      "optional": true
    }
  }
}
