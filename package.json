{
  "name": "@batou.dev/eslint-config",
  "version": "0.1.1",
  "description": "Reusable ESLint configuration with JavaScript and TypeScript support",
  "license": "MIT",
  "author": "Vincent Batoufflet <vincent@batou.dev>",
  "files": [
    "dist/",
    "CHANGELOG.md",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "type": "module",
  "scripts": {
    "build": "vite build && tsc --project tsconfig.build.json",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-externalize-deps": "^0.10.0"
  },
  "peerDependencies": {
    "@eslint/compat": "^2.0.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.2.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "peerDependenciesMeta": {
    "@eslint/compat": {
      "optional": true
    },
    "@stylistic/eslint-plugin": {
      "optional": false
    },
    "eslint": {
      "optional": false
    },
    "eslint-plugin-perfectionist": {
      "optional": false
    },
    "typescript": {
      "optional": true
    },
    "typescript-eslint": {
      "optional": true
    }
  }
}
